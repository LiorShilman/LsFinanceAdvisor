{
  "name": "ls-financial-advisor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node index.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:prod": "npm run build -- -c production",
    "build:dev": "ng build --base-href /LsFinanceAdvisor/ --configuration development",
    "electron": "electron",
    "electron:serve-tsc": "tsc -p tsconfig.serve.json",
    "electron:serve": "wait-on tcp:4200 && npm run electron:serve-tsc && electron . --serve",
    "electron:local-dev": "npm run build:dev && electron .",
    "electron:local": "npm run build:prod && electron .",
    "electron:build": "npm run build:prod && electron-builder build --publish=never",
    "electron:build-dev": "npm run build:dev && electron-builder build --publish=never"
  },
  "main": "app/main.js",
  "private": true,
  "dependencies": {
    "@angular/animations": "17.3.9",
    "@angular/common": "17.3.9",
    "@angular/compiler": "^17.3.9",
    "@angular/core": "17.3.9",
    "@angular/fire": "17.1.0",
    "@angular/forms": "17.3.9",
    "@angular/platform-browser": "17.3.9",
    "@angular/platform-browser-dynamic": "17.3.9",
    "@angular/router": "^17.3.9",
    "@angular/service-worker": "17.3.9",
    "@langchain/community": "^0.2.25",
    "@langchain/openai": "^0.2.6",
    "@ng-bootstrap/ng-bootstrap": "16.0.0",
    "@ng-bootstrap/schematics": "^2.0.0-alpha.1",
    "@popperjs/core": "^2.11.8",
    "@vitalets/google-translate-api": "^9.2.0",
    "bootstrap": "5.3.3",
    "bootstrap-icons": "1.11.3",
    "chart.js": "^4.4.0",
    "chartjs-plugin-annotation": "^3.0.1",
    "core-js": "^3.32.2",
    "electron": "^30.0.6",
    "electron-builder": "24.13.3",
    "electron-debug": "3.2.0",
    "electron-reloader": "1.2.3",
    "express": "^4.18.2",
    "firebase": "10.12.0",
    "highcharts": "^11.2.0",
    "highcharts-angular": "^3.1.2",
    "jquery": "^3.7.1",
    "katex": "^0.16.22",
    "langchain": "^0.0.200",
    "openai": "^4.47.1",
    "or": "^0.2.0",
    "popper.js": "^1.16.1",
    "rxfire": "^6.0.5",
    "rxjs": "~7.8.0",
    "sqlite3": "^5.1.6",
    "tslib": "^2.3.0",
    "zone.js": "0.14.6"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "17.0.2",
    "@angular-devkit/build-angular": "17.3.7",
    "@angular/cli": "17.3.7",
    "@angular/compiler-cli": "17.3.9",
    "@types/chrome": "0.0.268",
    "@types/core-js": "2.5.8",
    "@types/jasmine": "5.1.4",
    "@types/katex": "^0.16.7",
    "@types/node-fetch": "2.6.11",
    "html2pdf.js": "0.10.1",
    "jasmine-core": "~5.1.2",
    "karma": "6.4.3",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "typescript": "5.4.5"
  }
}
